<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main>
  <%- include('../partials/page-hero', {
    eyebrow: 'Realisations',
    title: "Des sites penses pour rassurer, convaincre et donner envie de passer a l'action.",
    description: "Voici quelques exemples de directions que je peux mettre en place selon ton activite, ton niveau de maturite et la maniere dont tes clients te cherchent."
  }) %>

  <section class="section">
