<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main>
  <%- include('../partials/page-hero', {
    eyebrow: 'À propos',
    title: 'Une approche exigeante pour des sites qui inspirent confiance.',
    description: 'Le studio se présente comme un atelier digital capable de transformer des maquettes fortes en une base robuste, maintenable et adaptable.'
  }) %>

  <section class="section">
    <div class="container split-grid">
      <div class="reveal">
        <h2>Notre vision</h2>
