<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main>
  <%- include('../partials/page-hero', {
    eyebrow: 'Contact',
    title: "Parle-moi de ton projet, je te dirai ce qui est possible.",
    description: "Que tu aies besoin d'un premier site, d'une refonte ou d'un site qui t'aide enfin a etre trouve sur Google, on peut commencer par un echange simple."
  }) %>

  <section class="section">
    <div class="container contact-premium-grid">
      <section class="contact-premium-form-wrap reveal">
        <h2>Explique-moi ou tu en es</h2>

        <form class="contact-premium-form" action="/contact" method="post" novalidate>
          <% if (status === 'ok') { %>
            <p class="alert success">Merci, ta demande a bien ete envoyee.</p>
          <% } %>
          <% if (status === 'invalid') { %>
            <p class="alert error">Verifie simplement les champs requis et ton adresse email.</p>
          <% } %>
          <% if (status === 'error') { %>
            <p class="alert error">Une erreur est survenue. Tu peux reessayer dans un instant.</p>
          <% } %>
          <% if (status === 'rate-limited') { %>
            <p class="alert error">Tu as atteint la limite de messages pour le moment. Reessaie un peu plus tard.</p>
          <% } %>

          <div class="contact-premium-two-col">
            <div class="contact-premium-field">
              <label for="fullname">Nom complet</label>
              <input id="fullname" name="fullname" type="text" required minlength="2" maxlength="120" placeholder="Jean Dupont" />
            </div>
            <div class="contact-premium-field">
              <label for="email">Email professionnel</label>
              <input id="email" name="email" type="email" required placeholder="jean@startup.io" />
            </div>
          </div>

          <div class="contact-premium-field">
            <label for="company">Entreprise</label>
            <input id="company" name="company" type="text" maxlength="120" placeholder="Nom de votre entreprise" />
          </div>

          <div class="contact-premium-projects">
            <p class="contact-premium-label">Type de projet</p>
            <div class="contact-premium-choice-list">
              <% ["Site vitrine", "Refonte", "SEO", "Autre"].forEach(function(option) { %>
                <label class="contact-premium-choice">
                  <input name="projectType" type="radio" value="<%= option %>" />
                  <span><%= option %></span>
                </label>
              <% }) %>
            </div>
          </div>

          <div class="contact-premium-field">
            <label for="message">Ton message</label>
            <textarea id="message" name="message" rows="5" placeholder="Dis-moi ce que tu fais, ce dont tu as besoin, ou ce qui bloque aujourd'hui..."></textarea>
          </div>

          <input class="honeypot" type="text" name="website" tabindex="-1" autocomplete="off" />

          <div class="contact-premium-actions">
            <button type="submit" class="btn">Envoyer ma demande</button>
          </div>
        </form>
      </section>

      <aside class="contact-premium-aside reveal reveal-delay">
        <div class="contact-premium-card">
          <p class="chip">Premier echange</p>
          <h3>On commence simplement, sans jargon et sans pression.</h3>
          <p>Tu m'expliques ton activite, ton objectif et ton contexte. Je reviens vers toi avec une reponse claire sur ce qu'on peut faire ensemble.</p>
        </div>

        <div class="contact-premium-meta">
          <article class="contact-premium-card">
            <h4>Email</h4>
            <p><%= site.email %></p>
          </article>
          <article class="contact-premium-card">
            <h4>Telephone</h4>
            <p><%= site.phone %></p>
          </article>
          <article class="contact-premium-card">
            <h4>Adresse</h4>
            <p><%= site.address %></p>
          </article>
          <article class="contact-premium-card">
            <h4>Delai de reponse</h4>
            <p>24 a 48h ouvrees</p>
          </article>
        </div>
      </aside>
    </div>
  </section>
</main>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
